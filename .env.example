# Copy to .env and fill in your values

# LLM provider: "openai", "ollama" or "ollama-cloud"
LLM_PROVIDER=ollama

# Model temperature (0.0 - 1.0)
LLM_TEMPERATURE=0.3

# OpenAI config (when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here
# LLM_MODEL=gpt-4o-mini

# Local Ollama config (when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=gemma2:2b
OLLAMA_NUM_CTX=4096

# Ollama Cloud config (when LLM_PROVIDER=ollama-cloud)
# Get your API key at: https://ollama.com/settings/keys
# OLLAMA_API_KEY=your-ollama-cloud-api-key
# LLM_MODEL=gemma2:2b
# OLLAMA_NUM_CTX=4096

# GuardRails.io — LLM input/output validation
# Get your key at: https://hub.guardrails.io/keys
GUARDRAILS_API_KEY=your-guardrails-key-here
