# Copy to .env and fill in your values

# LLM provider: "ollama-cloud" (default) or "ollama" (local — requires Docker Ollama service)
LLM_PROVIDER=ollama-cloud

# Model temperature (0.0 - 1.0)
LLM_TEMPERATURE=0.3

# Ollama Cloud config — get your API key at: https://ollama.com/settings/keys
OLLAMA_API_KEY=your-ollama-cloud-api-key
LLM_MODEL=gpt-oss:120b

# Local Ollama config (when LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://ollama:11434
# LLM_MODEL=gemma2:2b

# OpenAI — required for text-embedding-3-small (RAG indexing and search)
OPENAI_API_KEY=your-openai-api-key-here

# Internal communication with the PHP backend (RAG search endpoint)
# Must match INTERNAL_API_TOKEN in the backend .env
# Generate with: openssl rand -hex 32
BACKEND_BASE_URL=http://php:80
INTERNAL_API_TOKEN=change-me-use-openssl-rand-hex-32

# GuardRails.io — LLM input/output validation
# Get your key at: https://hub.guardrails.io/keys
GUARDRAILS_API_KEY=your-guardrails-key-here
